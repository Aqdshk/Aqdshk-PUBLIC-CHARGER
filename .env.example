# ============================================
# PlagSini EV â€” Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# -- Domain & SSL --
DOMAIN=your-domain.com
EMAIL_SSL=your-email@gmail.com
APP_ENV=development

# -- MySQL Database --
MYSQL_ROOT_PASSWORD=change-this-strong-password
MYSQL_DATABASE=charging_platform
MYSQL_USER=charging_user
MYSQL_PASSWORD=change-this-strong-password

# -- SMTP (Gmail App Password) --
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=PlagSini EV

# -- Gemini AI (optional, free tier) --
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# -- Payment callback protection (required) --
# Must match X-Callback-Secret header sent by payment gateway/webhook service.
PAYMENT_CALLBACK_SECRET=change-this-callback-secret

# -- Payment gateway API credentials (env-only, recommended) --
# Format: PAYMENT_<GATEWAY_NAME>_API_KEY / PAYMENT_<GATEWAY_NAME>_API_SECRET
# Example gateways currently supported in backend:
PAYMENT_BILLPLZ_API_KEY=
PAYMENT_BILLPLZ_API_SECRET=
PAYMENT_FIUU_API_KEY=
PAYMENT_FIUU_API_SECRET=
PAYMENT_TNG_API_KEY=
PAYMENT_TNG_API_SECRET=
PAYMENT_OCBC_API_KEY=
PAYMENT_OCBC_API_SECRET=
# Legacy fallback (not recommended): 1 to read DB-stored secrets.
ALLOW_DB_GATEWAY_SECRETS=0

# -- JWT secret (required) --
# Generate a strong random value (example):
# python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=replace-with-strong-random-hex

# -- Bootstrap admin/staff (dev only; strong passwords required) --
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin
STAFF_EMAIL=
STAFF_PASSWORD=
STAFF_NAME=Staff Admin

# -- CORS origins (production must set explicit domain list, comma-separated) --
# Example: CORS_ORIGINS=https://portal.your-domain.com,https://api.your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -- OCPP WebSocket auth (recommended required) --
# Set to 1 to require charger token during WS connect.
OCPP_REQUIRE_AUTH=1
# Option A (shared token for all chargers):
OCPP_SHARED_TOKEN=replace-with-strong-ocpp-token
# Option B (per-charger token map, comma-separated):
# OCPP_CHARGER_TOKENS=CP001:tokenA,CP002:tokenB
OCPP_CHARGER_TOKENS=

# -- API Base URL (for Flutter app build) --
# Set to your domain when live
API_BASE_URL=https://your-domain.com/api
BOT_BASE_URL=https://your-domain.com

# -- Grafana Monitoring (required) --
# Access dashboard at: http://localhost:3001 (via SSH tunnel from VPS)
# Generate strong password: python3 -c "import secrets; print(secrets.token_hex(16))"
GRAFANA_USER=admin
GRAFANA_PASSWORD=replace-with-strong-password

# -- OCPI 2.2.1 (TNG roaming integration) --
# Base URL for OCPI endpoints (e.g. https://api.your-domain.com)
OCPI_BASE_URL=
# Token for Authorization: Token {value} (eMSP uses when calling us)
OCPI_TOKEN=
# Party ID (3 chars, e.g. PLG for PlagSini)
OCPI_PARTY_ID=PLG
# Country code (2 chars)
OCPI_COUNTRY_CODE=MY
# Location defaults (optional)
OCPI_LOCATION_ADDRESS=Charging Station
OCPI_LOCATION_CITY=Kuala Lumpur
OCPI_LOCATION_POSTAL=50000
OCPI_LOCATION_LAT=3.1390
OCPI_LOCATION_LON=101.6869
