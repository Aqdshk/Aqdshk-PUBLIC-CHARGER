# ============================================================
# PlagSini EV — Production Environment Variables
# Copy this file to .env on your VPS and fill in all values.
#
# Usage on VPS:
#   cp .env.production.example .env
#   nano .env
# ============================================================

# ── Domain ──────────────────────────────────────────────────
# Your VPS domain or IP (no trailing slash)
DOMAIN=api.plagsini.com
APP_BASE_URL=https://api.plagsini.com

# ── MySQL Database ───────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_THIS_root_password
MYSQL_DATABASE=charging_platform
MYSQL_USER=charging_user
MYSQL_PASSWORD=CHANGE_THIS_db_password

# ── JWT Secret (generate with: openssl rand -hex 64) ────────
JWT_SECRET_KEY=CHANGE_THIS_generate_with_openssl_rand_hex_64

# ── Admin Accounts ───────────────────────────────────────────
ADMIN_EMAIL=admin@plagsini.com
ADMIN_PASSWORD=CHANGE_THIS_strong_password
ADMIN_NAME=Admin

STAFF_EMAIL=staff@plagsini.com
STAFF_PASSWORD=CHANGE_THIS_strong_password
STAFF_NAME=Staff Admin

# ── Email (Gmail App Password) ───────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
SMTP_FROM_NAME=PlagSini EV

# ── CORS (comma-separated, e.g. your Flutter web app URL) ───
CORS_ORIGINS=https://app.plagsini.com

# ── OCPP WebSocket Auth ──────────────────────────────────────
# Set to 1 to require token from chargers, 0 to disable
OCPP_REQUIRE_AUTH=1
# Shared token (if all chargers use same token)
OCPP_SHARED_TOKEN=CHANGE_THIS_generate_random_token
# Per-charger tokens (JSON format, optional)
# OCPP_CHARGER_TOKENS={"ESP32-CP-01":"token1","ESP32-CP-02":"token2"}

# ── Payment Gateways (fill in when ready) ────────────────────
PAYMENT_CALLBACK_SECRET=
PAYMENT_BILLPLZ_API_KEY=
PAYMENT_BILLPLZ_API_SECRET=
PAYMENT_FIUU_API_KEY=
PAYMENT_FIUU_API_SECRET=
PAYMENT_TNG_API_KEY=
PAYMENT_TNG_API_SECRET=
PAYMENT_OCBC_API_KEY=
PAYMENT_OCBC_API_SECRET=
ALLOW_DB_GATEWAY_SECRETS=0

# ── OCPI 2.2.1 (TNG Roaming — fill in when TNG provides docs) ──
OCPI_BASE_URL=https://api.plagsini.com
OCPI_TOKEN=CHANGE_THIS_generate_random_token
OCPI_PARTY_ID=PLG
OCPI_COUNTRY_CODE=MY
OCPI_LOCATION_ADDRESS=Your Charging Station Address
OCPI_LOCATION_CITY=Kuala Lumpur
OCPI_LOCATION_POSTAL=50000
OCPI_LOCATION_LAT=3.1390
OCPI_LOCATION_LON=101.6869

# ── API / Bot URLs (for inter-service communication) ────────
API_BASE_URL=https://api.plagsini.com/api
BOT_BASE_URL=https://api.plagsini.com

# ── AI / External API Keys ───────────────────────────────────
GEMINI_API_KEY=
